{
	"name": "rajshekar",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"zod": "^4.3.6",
			"@cloudflare/workers-types": "4.20260312.1",
			"hono": "4.12.7",
			"@orpc/server": "1.13.6",
			"@orpc/openapi": "1.13.6",
			"@orpc/zod": "1.13.6",
			"better-auth": "1.5.5",
			"alchemy": "0.89.0",
			"wrangler": "4.72.0",
			"@iconify/react": "6.0.2",
			"next-themes": "0.4.6",
			"sonner": "2.0.7",
			"tailwindcss": "4.2.1",
			"@libsql/client": "0.17.0",
			"libsql": "0.5.22",
			"@orpc/client": "1.13.6",
			"@orpc/tanstack-query": "1.13.6",
			"@tanstack/react-form": "1.28.5",
			"@types/react-dom": "19.2.3",
			"@better-auth/expo": "^1.5.5",
			"resend": "^6.9.3",
			"drizzle-orm": "0.45.1",
			"@types/node": "^22.19.15",
			"typescript": "^5.9.3"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"biome": "bunx --bun @biomejs/biome check --write",
		"check-types": "turbo check-types",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F server dev",
		"db:push": "turbo -F @rajshekar/db db:push",
		"db:generate": "turbo -F @rajshekar/db db:generate",
		"deploy": "turbo -F @rajshekar/infra deploy",
		"destroy": "turbo -F @rajshekar/infra destroy",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@better-auth/utils": "^0.3.1",
		"resend": "catalog:",
		"varlock": "^0.4.2",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@cloudflare/workers-types": "catalog:",
		"@rajshekar/config": "workspace:*",
		"@types/node": "catalog:",
		"turbo": "^2.8.16",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.10"
}
